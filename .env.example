# ── LiveKit Connection ──
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── AI Service API Keys ──
DEEPGRAM_API_KEY=your_deepgram_api_key
GEMINI_API_KEY=your_gemini_api_key

# OpenAI — REQUIRED for a live demo, and the default primary.
#
# This is about rate limits, not model quality. Measured against this agent's
# ~3,000-token-per-turn prompt:
#
#   Gemini free tier   5 turns/min   (hard 5 RPM cap — verified with a live 429)
#   Groq free tier    ~4 turns/min   (12,000 TPM budget ÷ ~3k tokens per turn)
#   OpenAI 4o-mini   ~67 turns/min   (500 RPM / 200k TPM)
#
# A real conversation is 15-30 turns. Both free tiers run dry mid-call and the
# agent goes silent — which looks like a crash in front of a client.
OPENAI_API_KEY=your_openai_api_key

# PRIMARY LLM vendor: openai | gemini | groq
# Every other reachable vendor is chained as a fallback automatically, so a
# rate-limited primary fails over instead of dropping the call. The wrapper is
# free on the happy path (measured: 225.1ms bare vs 214.8ms wrapped).
#
# Set to "gemini" ONLY if GEMINI_API_KEY is on a paid tier — Gemini 2.5 Flash is
# the better model for persona nuance and gets implicit prompt caching, but its
# free tier cannot survive a demo.
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# Groq — works, and serves as the second fallback vendor. Llama-70B is slower to
# first token than Gemini/GPT on long prompts, which is why the per-attempt LLM
# timeout must stay generous (see LLM_ATTEMPT_TIMEOUT); at 5s it was being
# cancelled mid-generation once the prompt grew with retrieved context.
GROQ_API_KEY=your_groq_api_key

# Per-attempt LLM timeout, seconds. DO NOT set below 10: Gemini rejects any
# deadline under 10s with a non-retryable 400 and the agent goes silent. This is
# a ceiling, not a wait — a healthy LLM replying in 300ms is unaffected.
LLM_ATTEMPT_TIMEOUT=12

# Optional second TTS provider (free tier available at cartesia.ai).
# Leave empty and the voice catalog simply shows Deepgram's 12 curated voices;
# set it and Cartesia Sonic-3 voices are discovered from your account and appear
# in the demo's voice picker automatically.
CARTESIA_API_KEY=

# ── Public voice demo (/demo) ──
# Which tenant's knowledge base the public demo page talks to.
DEMO_TENANT_ID=lumenia

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://nexus:nexus_dev_password@postgres:5432/nexus_dispatch
POSTGRES_PASSWORD=nexus_dev_password

# ── Authentication ──
JWT_SECRET=change_this_to_a_random_64_char_string_in_production

# Service-to-service auth: the agent worker authenticates to the TMS backend
# with this shared key. MUST be identical in the agent and backend environments.
NEXUS_SERVICE_KEY=change_this_to_a_random_service_key

# ── TMS Backend (default, overridden per tenant) ──
TMS_BASE_URL=http://tms-backend:8000

# ── Redis (shared state across agent workers) ──
REDIS_URL=redis://redis:6379/0

# ── Multi-Tenant Config ──
TENANTS_CONFIG_PATH=config/tenants.json
DEFAULT_TENANT_ID=abc-logistics

# ── Telephony (Telnyx — use GitHub Student Pack for free credits) ──
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_SIP_URI=sip:your-connection-id@sip.telnyx.com

# Outbound SIP trunk id on LiveKit (Phase 1 outbound dialing — optional for now)
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# ── Call recording (LiveKit Egress) ──
RECORDING_ENABLED=false

# ── Email (Resend — free tier: 100 emails/day) ──
RESEND_API_KEY=your_resend_api_key
