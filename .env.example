# ── LiveKit Connection ──
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── AI Service API Keys ──
DEEPGRAM_API_KEY=your_deepgram_api_key
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql+asyncpg://nexus:nexus_dev_password@postgres:5432/nexus_dispatch
POSTGRES_PASSWORD=nexus_dev_password

# ── Authentication ──
JWT_SECRET=change_this_to_a_random_64_char_string_in_production

# ── TMS Backend (default, overridden per tenant) ──
TMS_BASE_URL=http://tms-backend:8000

# ── Redis (shared state across agent workers) ──
REDIS_URL=redis://redis:6379/0

# ── Multi-Tenant Config ──
TENANTS_CONFIG_PATH=config/tenants.json
DEFAULT_TENANT_ID=abc-logistics

# ── Telephony (Telnyx — use GitHub Student Pack for free credits) ──
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_SIP_URI=sip:your-connection-id@sip.telnyx.com

# ── Email (Resend — free tier: 100 emails/day) ──
RESEND_API_KEY=your_resend_api_key
